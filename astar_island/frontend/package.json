{
  "name": "astar-island-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.2",
  "scripts": {
    "sync-data": "bun run scripts/generate-data.ts",
    "save-prediction": "bun run scripts/save-prediction.ts",
    "dev": "bun run scripts/generate-data.ts && vite",
    "build": "bun run scripts/generate-data.ts && tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.167.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.8.2",
    "vite": "^7.0.0"
  }
}
